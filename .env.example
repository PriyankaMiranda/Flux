# Flux Worker Pipeline Configuration
# Copy to .env and adjust values for your environment

# ============ APPLICATION ============
MIX_ENV=dev
LOG_LEVEL=info

# ============ DATABASE (TimescaleDB) ============
DATABASE_URL=postgres://postgres:password@localhost:5432/flux
DB_POOL_SIZE=10
DB_TIMEOUT_MS=5000

# ============ PUBSUB (Redis) ============
REDIS_URL=redis://localhost:6379
REDIS_TIMEOUT_MS=1000

# ============ DATA SOURCES ============

# Alpha Vantage (Stock prices)
ALPHAVANTAGE_KEY=demo
ALPHAVANTAGE_INTERVAL=60s

# News API (Market news)
NEWSAPI_KEY=demo
NEWSAPI_INTERVAL=30s

# ============ WORKER CONFIGURATION ============
WORKERS_CONFIG_PATH=config/workers.yaml
WORKER_POLL_INTERVAL=5000

# ============ ALGORITHM SETTINGS ============
ALGORITHM_CACHE_WINDOW=100
ALGORITHM_BATCH_SIZE=10

# ============ LOGGING ============
ENABLE_LOGGING=true
LOG_FORMAT=json
LOG_LEVEL=info
